{
  "manifest_version": 2,
  "name": "FF Tab Exposé",
  "version": "1.0.0",
  "description": "Visual Safari-style tab overview",

  "permissions": ["tabs", "activeTab", "<all_urls>", "storage"],

  "icons": {
    "48": "icons/rectangle.on.rectangle.svg",
    "96": "icons/rectangle.on.rectangle.svg"
  },

  "browser_action": {
    "default_icon": "icons/rectangle.on.rectangle.light.svg",
    "theme_icons": [
      {
        "light": "icons/rectangle.on.rectangle.dark.svg",
        "dark": "icons/rectangle.on.rectangle.light.svg",
        "size": 16
      },
      {
        "light": "icons/rectangle.on.rectangle.dark.svg",
        "dark": "icons/rectangle.on.rectangle.light.svg",
        "size": 32
      }
    ],
    "default_title": "Tab Exposé"
  },

  "commands": {
    "open-expose": {
      "suggested_key": {
        "mac": "Command+Shift+E",
        "default": "Ctrl+Shift+E"
      },
      "description": "Open Tab Exposé"
    }
  },

  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "page_action": {},

  "web_accessible_resources": ["expose.html"],

  "browser_specific_settings": {
    "gecko": {
      "id": "tab-expose@extension",
      "strict_min_version": "91.0"
    }
  }
}
